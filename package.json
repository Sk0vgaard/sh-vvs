{
  "name": "sh-vvs",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/generate-firebase-secrets.mjs && ng serve",
    "prebuild": "node scripts/generate-firebase-secrets.mjs",
    "build": "ng build",
    "setup:firebase": "node scripts/generate-firebase-secrets.mjs --force",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:html": "html-validate \"src/app/**/*.html\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:functions": "npm run build --prefix functions",
    "build:all": "npm run build && npm run build:functions",
    "deploy": "npm run build:all && npx firebase deploy --only functions:submitContact,hosting && npm run smoke:contact",
    "smoke:contact": "node scripts/smoke-test-contact-form.mjs",
    "firebase:emulators": "firebase emulators:start --only hosting"
  },
  "private": true,
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@fontsource/inter": "^5.2.6",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "firebase": "^12.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase-tools": "^15.19.0",
    "html-validate": "^10.17.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "sass": "^1.100.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
